---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  isHome?: boolean;
  noindex?: boolean;
}

const {
  title,
  description = 'Cotizaciones semanales del mercado porcino español: porcino blanco, ibérico, lechones y desvieje. Referencia de la Lonja de Binéfar y Lleida.',
  isHome = false,
  noindex = false,
} = Astro.props;

const siteName = 'Lonja Porcino';
const siteUrl  = 'https://lonjaporcino.es';

const pageTitle = isHome
  ? `${siteName} — Precios del mercado porcino español`
  : title
    ? `${title} · ${siteName}`
    : siteName;

const canonical = Astro.url.pathname === '/' ? siteUrl : `${siteUrl}${Astro.url.pathname}`;
const currentPath = Astro.url.pathname;

const ogImage = `${siteUrl}/og-default.png`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary -->
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:locale"      content="es_ES" />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Analytics -->
  <script defer src="https://umami-production-c3fa.up.railway.app/script.js" data-website-id="18126ee9-f090-4c02-a78e-130c5afd43ba"></script>

  <!-- Structured data — WebSite + Organization (todas las páginas) -->
  <script type="application/ld+json" is:raw>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://lonjaporcino.es/#website",
        "url": "https://lonjaporcino.es",
        "name": "Lonja Porcino",
        "description": "Directorio de lonjas porcinas españolas y cotizaciones semanales del mercado porcino",
        "inLanguage": "es"
      },
      {
        "@type": "Organization",
        "@id": "https://lonjaporcino.es/#organization",
        "name": "Lonja Porcino",
        "url": "https://lonjaporcino.es",
        "email": "contacto@lonjaporcino.es",
        "knowsAbout": ["mercado porcino español", "precios del cerdo", "lonjas porcinas", "cotizaciones porcino ibérico"]
      }
    ]
  }
  </script>

  <!-- Fonts (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" />
  </noscript>
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">Lonja<span>Porcino</span></a>
    <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="site-nav">☰</button>
    <nav class="site-nav" id="site-nav">
      <a href="/"        aria-current={currentPath === '/'                  ? 'page' : undefined}>Inicio</a>
      <a href="/precios" aria-current={currentPath === '/precios'           ? 'page' : undefined}>Precios</a>
      <a href="/lonjas"  aria-current={currentPath.startsWith('/lonjas')    ? 'page' : undefined}>Lonjas</a>
      <a href="/blog"    aria-current={currentPath.startsWith('/blog')      ? 'page' : undefined}>Blog</a>
      <a href="/sobre"   aria-current={currentPath === '/sobre'             ? 'page' : undefined}>Sobre</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>lonjaporcino.es · Precios orientativos, sin carácter contractual</p>
    <p>© {new Date().getFullYear()}</p>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
    const nav    = document.getElementById('site-nav');
    toggle?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    });
  </script>
</body>
</html>
