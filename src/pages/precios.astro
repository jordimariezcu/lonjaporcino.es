---
import Base from '../layouts/Base.astro';
import PreciosTable from '../components/PreciosTable.astro';
import { HistoricoChart } from '../components/HistoricoChart';
import type { SesionChartData } from '../components/HistoricoChart';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);

const toNum = (v: string | null | undefined): number | null => {
  if (!v) return null;
  const n = parseFloat(v);
  return isNaN(n) ? null : n;
};

const avg = (min: number | null, max: number | null): number | null => {
  if (min === null && max === null) return null;
  if (min === null) return max;
  if (max === null) return min;
  return Math.round(((min + max) / 2) * 1000) / 1000;
};

const allSesiones = await reader.collections.sesiones.all();
const sorted = allSesiones.sort((a, b) => a.slug.localeCompare(b.slug));
const sesion = sorted[sorted.length - 1];
const e = sesion?.entry;

const chartData: SesionChartData[] = sorted.map(s => {
  const d = s.entry;
  return {
    fecha: s.slug,
    blanco_selecto:     avg(toNum(d.blanco_selecto_min),     toNum(d.blanco_selecto_max)),
    blanco_normal:      avg(toNum(d.blanco_normal_min),      toNum(d.blanco_normal_max)),
    blanco_graso:       avg(toNum(d.blanco_graso_min),       toNum(d.blanco_graso_max)),
    lechon_nacional:    avg(toNum(d.lechon_nacional_min),    toNum(d.lechon_nacional_max)),
    lechon_importacion: avg(toNum(d.lechon_importacion_min), toNum(d.lechon_importacion_max)),
    cochinillo_marca:   avg(toNum(d.cochinillo_marca_min),   toNum(d.cochinillo_marca_max)),
    cochinillo_estandar:avg(toNum(d.cochinillo_estandar_min),toNum(d.cochinillo_estandar_max)),
    bellota_100:        avg(toNum(d.bellota_100_min),        toNum(d.bellota_100_max)),
    bellota_75:         avg(toNum(d.bellota_75_min),         toNum(d.bellota_75_max)),
    bellota_50:         avg(toNum(d.bellota_50_min),         toNum(d.bellota_50_max)),
    cebo_campo:         avg(toNum(d.cebo_campo_min),         toNum(d.cebo_campo_max)),
    cebo:               avg(toNum(d.cebo_min),               toNum(d.cebo_max)),
    lechones_ibericos:  avg(toNum(d.lechones_ibericos_min),  toNum(d.lechones_ibericos_max)),
    primales_ibericos:  avg(toNum(d.primales_ibericos_min),  toNum(d.primales_ibericos_max)),
    cerdas_unica:       avg(toNum(d.cerdas_unica_min),       toNum(d.cerdas_unica_max)),
    cerdas_extra:       avg(toNum(d.cerdas_extra_min),       toNum(d.cerdas_extra_max)),
    cerdas_desecho:     avg(toNum(d.cerdas_desecho_min),     toNum(d.cerdas_desecho_max)),
    verracos:           avg(toNum(d.verracos_min),           toNum(d.verracos_max)),
  };
});
---

<Base
  title="Precio del cerdo hoy — Cotización semanal"
  description="Precio del cerdo en España esta semana: porcino blanco (selecto, normal, graso), lechones, cochinillos, ibérico bellota y cebo, y desvieje. Cotizaciones semanales de la Lonja de Lleida y Binéfar."
>
  <script type="application/ld+json" is:raw>
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Cotizaciones semanales del mercado porcino español",
    "description": "Precios del porcino blanco (cerdo selecto, normal y graso), lechones nacionales y de importación, cochinillos, porcino ibérico (bellota 100%, 75%, 50%, cebo de campo y cebo) y desvieje. Sesiones de la Lonja de Lleida y referencia de la Lonja Agropecuaria de Binéfar.",
    "url": "https://lonjaporcino.es/precios",
    "keywords": ["precio cerdo", "cotización porcino", "lonja porcino", "precio ibérico bellota", "precio lechón", "desvieje porcino"],
    "publisher": {
      "@type": "Organization",
      "name": "Lonja Porcino",
      "url": "https://lonjaporcino.es"
    },
    "spatialCoverage": {
      "@type": "Place",
      "name": "España"
    },
    "inLanguage": "es"
  }
  </script>

  <section class="hero">
    <p class="hero-label">Precios del mercado porcino</p>
    <h1>Cotizaciones<br />semanales</h1>
    {sesion && (
      <p class="hero-sub">
        Última sesión: {sesion.slug}
        {sesion.entry.fuente ? ` · Fuente: ${sesion.entry.fuente}` : ''}
      </p>
    )}
  </section>

  <hr class="divider" />

  <div class="container">
    {sesion ? (
      <>
        <p class="section-label">Precios actuales · {sesion.slug}</p>

        <PreciosTable
          titulo="Porcino Blanco — Cebo"
          rows={[
            { nombre: 'Cerdo Selecto', min: toNum(e?.blanco_selecto_min), max: toNum(e?.blanco_selecto_max), unidad: '€/kg canal' },
            { nombre: 'Cerdo Normal',  min: toNum(e?.blanco_normal_min),  max: toNum(e?.blanco_normal_max),  unidad: '€/kg canal' },
            { nombre: 'Cerdo Graso',   min: toNum(e?.blanco_graso_min),   max: toNum(e?.blanco_graso_max),   unidad: '€/kg canal' },
          ]}
        />

        <PreciosTable
          titulo="Lechones y Cochinillos"
          rows={[
            { nombre: 'Lechón Nacional (base 20 kg)',     min: toNum(e?.lechon_nacional_min),    max: toNum(e?.lechon_nacional_max),    unidad: '€/ud' },
            { nombre: 'Lechón Importación (base 20 kg)',  min: toNum(e?.lechon_importacion_min), max: toNum(e?.lechon_importacion_max), unidad: '€/ud' },
            { nombre: 'Cochinillo con marca',             min: toNum(e?.cochinillo_marca_min),   max: toNum(e?.cochinillo_marca_max),   unidad: '€/kg' },
            { nombre: 'Cochinillo estándar',              min: toNum(e?.cochinillo_estandar_min),max: toNum(e?.cochinillo_estandar_max),unidad: '€/kg' },
          ]}
        />

        <PreciosTable
          titulo="Porcino Ibérico"
          rows={[
            { nombre: 'Bellota 100% pureza racial', min: toNum(e?.bellota_100_min),       max: toNum(e?.bellota_100_max),       unidad: '€/kg vivo' },
            { nombre: 'Bellota 75%',                min: toNum(e?.bellota_75_min),        max: toNum(e?.bellota_75_max),        unidad: '€/kg vivo' },
            { nombre: 'Bellota 50%',                min: toNum(e?.bellota_50_min),        max: toNum(e?.bellota_50_max),        unidad: '€/kg vivo' },
            { nombre: 'Cebo de Campo',              min: toNum(e?.cebo_campo_min),        max: toNum(e?.cebo_campo_max),        unidad: '€/kg vivo' },
            { nombre: 'Cebo',                       min: toNum(e?.cebo_min),              max: toNum(e?.cebo_max),              unidad: '€/kg vivo' },
            { nombre: 'Lechones Ibéricos',          min: toNum(e?.lechones_ibericos_min), max: toNum(e?.lechones_ibericos_max), unidad: '€/ud' },
            { nombre: 'Primales Ibéricos',          min: toNum(e?.primales_ibericos_min), max: toNum(e?.primales_ibericos_max), unidad: '€/kg vivo' },
          ]}
        />

        <PreciosTable
          titulo="Desvieje"
          rows={[
            { nombre: 'Cerdas — Única',   min: toNum(e?.cerdas_unica_min),   max: toNum(e?.cerdas_unica_max),   unidad: '€/kg canal' },
            { nombre: 'Cerdas — Extra',   min: toNum(e?.cerdas_extra_min),   max: toNum(e?.cerdas_extra_max),   unidad: '€/kg canal' },
            { nombre: 'Cerdas — Desecho', min: toNum(e?.cerdas_desecho_min), max: toNum(e?.cerdas_desecho_max), unidad: '€/kg canal' },
            { nombre: 'Verracos',         min: toNum(e?.verracos_min),        max: toNum(e?.verracos_max),        unidad: '€/kg canal' },
          ]}
        />

        {sesion.entry.notas && (
          <p style="font-size:0.85rem; color:var(--muted); margin-top:1rem; font-style:italic;">
            {sesion.entry.notas}
          </p>
        )}
      </>
    ) : (
      <p style="color: var(--muted); padding: 2rem 0;">No hay sesiones publicadas todavía.</p>
    )}

    <div class="contexto" style="margin-top: 2.5rem;">
      <h2>Cotización semanal del porcino en España</h2>
      <p>
        Los precios recogen las principales categorías negociadas en sesión:
        <strong>porcino blanco de cebo</strong> (cerdo selecto, normal y graso en €/kg canal),
        <strong>lechones</strong> nacionales y de importación (€/ud, base 20 kg),
        <strong>cochinillos</strong> con marca y estándar (€/kg),
        <strong>porcino ibérico</strong> según denominación —bellota 100%, 75% y 50%, cebo de campo y cebo— (€/kg vivo),
        y <strong>desvieje</strong> —cerdas y verracos— (€/kg canal).
      </p>
      <p>
        Las cotizaciones son orientativas y se publican con periodicidad semanal a partir de las sesiones
        de la <strong>Lonja de Lleida</strong>, principal referencia nacional del precio del cerdo en España,
        y de la <strong>Lonja Agropecuaria de Binéfar</strong>.
      </p>
    </div>

    <p class="section-label">Evolución histórica de precios</p>
    <HistoricoChart sesiones={chartData} client:load />
  </div>
</Base>
