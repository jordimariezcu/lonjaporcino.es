---
import Base from '../layouts/Base.astro';
import PreciosTable from '../components/PreciosTable.astro';
import BlogCard from '../components/BlogCard.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { getCollection } from 'astro:content';

const reader = createReader(process.cwd(), keystaticConfig);

const toNum = (v: string | null | undefined): number | null => {
  if (!v) return null;
  const n = parseFloat(v);
  return isNaN(n) ? null : n;
};

const allSesiones = await reader.collections.sesiones.all();
const sesion = allSesiones.sort((a, b) => b.slug.localeCompare(a.slug))[0];
const e = sesion?.entry;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => (b.data.fecha ?? '').localeCompare(a.data.fecha ?? ''))
  .slice(0, 3);

function fmtFecha(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base title="Inicio">
  <section class="hero">
    {sesion
      ? <p class="hero-label">Última sesión · {fmtFecha(sesion.slug)} · {e?.fuente ?? ''}</p>
      : <p class="hero-label">Precios del mercado porcino</p>
    }
    <h1>Precios del mercado<br />porcino en España</h1>
    <p class="hero-sub">Cotizaciones actualizadas semanalmente</p>
  </section>

  <hr class="divider" />

  <div class="container">
    {sesion ? (
      <>
        <p class="section-label">Precios actuales · {fmtFecha(sesion.slug)}</p>

        <PreciosTable
          titulo="Porcino Blanco — Cebo"
          rows={[
            { nombre: 'Cerdo Selecto', min: toNum(e?.blanco_selecto_min), max: toNum(e?.blanco_selecto_max), unidad: '€/kg canal' },
            { nombre: 'Cerdo Normal',  min: toNum(e?.blanco_normal_min),  max: toNum(e?.blanco_normal_max),  unidad: '€/kg canal' },
            { nombre: 'Cerdo Graso',   min: toNum(e?.blanco_graso_min),   max: toNum(e?.blanco_graso_max),   unidad: '€/kg canal' },
          ]}
        />

        <PreciosTable
          titulo="Lechones y Cochinillos"
          rows={[
            { nombre: 'Lechón Nacional (base 20 kg)',    min: toNum(e?.lechon_nacional_min),    max: toNum(e?.lechon_nacional_max),    unidad: '€/ud' },
            { nombre: 'Lechón Importación (base 20 kg)', min: toNum(e?.lechon_importacion_min), max: toNum(e?.lechon_importacion_max), unidad: '€/ud' },
            { nombre: 'Cochinillo con marca',            min: toNum(e?.cochinillo_marca_min),   max: toNum(e?.cochinillo_marca_max),   unidad: '€/kg' },
            { nombre: 'Cochinillo estándar',             min: toNum(e?.cochinillo_estandar_min),max: toNum(e?.cochinillo_estandar_max),unidad: '€/kg' },
          ]}
        />

        <PreciosTable
          titulo="Porcino Ibérico"
          rows={[
            { nombre: 'Bellota 100% pureza racial', min: toNum(e?.bellota_100_min),       max: toNum(e?.bellota_100_max),       unidad: '€/kg vivo' },
            { nombre: 'Bellota 75%',                min: toNum(e?.bellota_75_min),        max: toNum(e?.bellota_75_max),        unidad: '€/kg vivo' },
            { nombre: 'Bellota 50%',                min: toNum(e?.bellota_50_min),        max: toNum(e?.bellota_50_max),        unidad: '€/kg vivo' },
            { nombre: 'Cebo de Campo',              min: toNum(e?.cebo_campo_min),        max: toNum(e?.cebo_campo_max),        unidad: '€/kg vivo' },
            { nombre: 'Cebo',                       min: toNum(e?.cebo_min),              max: toNum(e?.cebo_max),              unidad: '€/kg vivo' },
            { nombre: 'Lechones Ibéricos',          min: toNum(e?.lechones_ibericos_min), max: toNum(e?.lechones_ibericos_max), unidad: '€/ud' },
            { nombre: 'Primales Ibéricos',          min: toNum(e?.primales_ibericos_min), max: toNum(e?.primales_ibericos_max), unidad: '€/kg vivo' },
          ]}
        />

        <PreciosTable
          titulo="Desvieje"
          rows={[
            { nombre: 'Cerdas — Única',   min: toNum(e?.cerdas_unica_min),   max: toNum(e?.cerdas_unica_max),   unidad: '€/kg canal' },
            { nombre: 'Cerdas — Extra',   min: toNum(e?.cerdas_extra_min),   max: toNum(e?.cerdas_extra_max),   unidad: '€/kg canal' },
            { nombre: 'Cerdas — Desecho', min: toNum(e?.cerdas_desecho_min), max: toNum(e?.cerdas_desecho_max), unidad: '€/kg canal' },
            { nombre: 'Verracos',         min: toNum(e?.verracos_min),        max: toNum(e?.verracos_max),        unidad: '€/kg canal' },
          ]}
        />
      </>
    ) : (
      <p style="color: var(--muted); padding: 2rem 0;">No hay sesiones de precios publicadas todavía.</p>
    )}

    <div class="contexto">
      <h2>El mercado porcino español y sus lonjas de referencia</h2>

      <p>
        Tras unos años de estabilización, el sector porcino ha retomado la senda del crecimiento.
        Entre Aragón y Cataluña se concentran más de la mitad de la cabaña nacional, siendo Aragón
        la comunidad con mayor número de animales. Sin embargo, este liderazgo en producción no ha
        venido acompañado históricamente de un peso equivalente en el control del mercado.
      </p>

      <h3>La Lonja de Lleida y las referencias europeas</h3>
      <p>
        La lonja de referencia en España para el precio del porcino es la de <strong>Lleida</strong>.
        Junto con las lonjas alemanas —especialmente la <em>Agricultural Market Information
        Company</em> (AMI) de Bonn— establece los precios de referencia en Europa y, por extensión,
        en el mercado español. Las cotizaciones de Lleida son seguidas semanalmente por productores,
        integradores, mataderos y operadores de todo el territorio nacional e internacional.
      </p>

      <h3>Cómo se fijan los precios</h3>
      <p>
        Las lonjas se rigen por modelos clásicos de propuesta de precio: una <strong>junta de
        precios</strong> formada por representantes de productores y operadores se reúne en sesión
        presencial y pone en común datos como pesos medios, volumen de cabaña y sacrificios de la
        semana. A partir de esa información, los participantes negocian la dirección —al alza o a
        la baja— y el rango aproximado de variación de las cotizaciones. El proceso, aunque
        consolidado, presenta bajos niveles de transparencia y auditoría sobre los datos de
        partida que cada parte aporta a la mesa.
      </p>
      <p>
        Las sesiones recogen distintas categorías: porcino blanco de cebo (cerdo selecto, normal y
        graso), lechones nacionales y de importación, cochinillos, porcino ibérico según su
        denominación (bellota 100%, 75% y 50%, cebo de campo y cebo) y animales de desvieje. Los
        precios se expresan en euros por kilogramo de peso vivo o canal según la categoría.
      </p>

      <h3>La Lonja Agropecuaria de Binéfar</h3>
      <p>
        La Lonja de Binéfar es un lugar de encuentro entre productores agropecuarios y empresas
        comercializadoras. Facilita a los primeros la planificación de sus explotaciones a la luz
        de los acuerdos que se toman en las sesiones semanales, ayudando a mantener la rentabilidad
        del negocio en un mercado de alta competitividad.
      </p>
      <p>
        Su importancia descansa sobre una infraestructura sin parangón: en un radio de 30 kilómetros
        se concentran 100.000 terneros, Binéfar acoge uno de los mataderos de mayor volumen de
        trabajo de la península, y en la zona operan innumerables fábricas de piensos, comerciales
        ganaderas y sociedades de servicios sanitarios. Esta estructura ha convertido a Binéfar en
        la <strong>primera referencia del vacuno español</strong>, con una influencia directa sobre
        más del 30% de la producción nacional de carne de vacuno.
      </p>
      <p>
        Las delegaciones comerciales de numerosos países de la Unión Europea siguen con atención la
        evolución de sus precios, y todas las asociaciones de mataderos y salas de despiece valoran
        los dictados de este mercado en origen. Los operadores que acuden a sus sesiones proceden de
        zonas muy alejadas: Madrid, Barcelona, Tarragona, Lleida, Valencia. Binéfar también marca la
        pauta en los cereales para pienso y la alfalfa, y los productores de ovino acuden a las
        sesiones para conocer las oscilaciones de la demanda de Cataluña.
      </p>
      <p>
        Este prestigio acumulado durante décadas en el vacuno es el punto de partida desde el que la
        Lonja de Binéfar trabaja por consolidar una referencia igualmente sólida para el porcino,
        dotando al sector aragonés de herramientas de mayor transparencia y rigor en la formación de
        precios.
      </p>
    </div>

    {posts.length > 0 && (
      <>
        <p class="section-label">Últimos análisis</p>
        <div class="blog-grid">
          {posts.map(post => (
            <BlogCard
              slug={post.slug}
              titulo={post.data.titulo}
              descripcion={post.data.descripcion ?? ''}
              fecha={post.data.fecha ?? ''}
              tags={post.data.tags ?? []}
            />
          ))}
        </div>
      </>
    )}
  </div>
</Base>
